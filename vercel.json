{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "mint-page/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/scripts/**",
      "use": "@vercel/static"
    },
    {
      "src": "data/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/authorize",
      "dest": "/api/authorize.js"
    },
    {
      "src": "/api/shuffle",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/mint",
      "dest": "/api/mint.js"
    },
    {
      "src": "/api/token/([0-9]+)",
      "dest": "/api/token/[id].js?id=$1"
    },
    {
      "src": "/api/render/([0-9]+)",
      "dest": "/api/render/[id].js?id=$1"
    },
    {
      "src": "/gallery",
      "dest": "/mint-page/gallery.html"
    },
    {
      "src": "/whitepaper",
      "dest": "/mint-page/whitepaper.html"
    },
    {
      "src": "/api/gallery",
      "dest": "/api/gallery.js"
    },
    {
      "src": "/api/utilities",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/genesis",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/holder",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/recent-mints",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/badge/([A-Z0-9]+)",
      "dest": "/api/badge.js?address=$1"
    },
    {
      "src": "/api/badge",
      "dest": "/api/badge.js"
    },
    {
      "src": "/api/aibtc-badge/([A-Z0-9]+)",
      "dest": "/api/aibtc-badge.js?address=$1"
    },
    {
      "src": "/api/aibtc-badge",
      "dest": "/api/aibtc-badge.js"
    },
    {
      "src": "/api/attest",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/eligibility",
      "dest": "/api/verify.js"
    },
    {
      "src": "/api/digest",
      "dest": "/api/gallery.js"
    },
    {
      "src": "/holders",
      "dest": "/mint-page/holders.html"
    },
    {
      "src": "/traits",
      "dest": "/mint-page/traits.html"
    },
    {
      "src": "/log",
      "dest": "/mint-page/log.html"
    },
    {
      "src": "/data/changelog.json",
      "dest": "/data/changelog.json"
    },
    {
      "src": "/eagle/([0-9]+)",
      "dest": "/mint-page/eagle.html"
    },
    {
      "src": "/holder/([A-Z0-9]+)",
      "dest": "/mint-page/holder.html"
    },
    {
      "src": "/scripts/(.*)",
      "dest": "/public/scripts/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/mint-page/index.html"
    }
  ]
}
