{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "mint-page/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/scripts/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/authorize",
      "dest": "/api/authorize.js"
    },
    {
      "src": "/api/shuffle",
      "dest": "/api/shuffle.js"
    },
    {
      "src": "/api/mint",
      "dest": "/api/mint.js"
    },
    {
      "src": "/api/token/([0-9]+)",
      "dest": "/api/token/[id].js?id=$1"
    },
    {
      "src": "/gallery",
      "dest": "/mint-page/gallery.html"
    },
    {
      "src": "/whitepaper",
      "dest": "/mint-page/whitepaper.html"
    },
    {
      "src": "/api/gallery",
      "dest": "/api/gallery.js"
    },
    {
      "src": "/scripts/render_eagle.py",
      "dest": "/public/scripts/render_eagle.py",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8",
        "Content-Disposition": "inline"
      }
    },
    {
      "src": "/scripts/render_eagle.mjs",
      "dest": "/public/scripts/render_eagle.mjs",
      "headers": {
        "Content-Type": "text/plain; charset=utf-8",
        "Content-Disposition": "inline"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/mint-page/index.html"
    }
  ]
}
