{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "mint-page/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/scripts/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/authorize",
      "dest": "/api/authorize.js"
    },
    {
      "src": "/api/shuffle",
      "dest": "/api/shuffle.js"
    },
    {
      "src": "/api/mint",
      "dest": "/api/mint.js"
    },
    {
      "src": "/api/token/([0-9]+)",
      "dest": "/api/token/[id].js?id=$1"
    },
    {
      "src": "/api/render/([0-9]+)",
      "dest": "/api/render/[id].js?id=$1"
    },
    {
      "src": "/gallery",
      "dest": "/mint-page/gallery.html"
    },
    {
      "src": "/whitepaper",
      "dest": "/mint-page/whitepaper.html"
    },
    {
      "src": "/api/gallery",
      "dest": "/api/gallery.js"
    },
    {
      "src": "/api/utilities",
      "dest": "/api/utilities.js"
    },
    {
      "src": "/api/genesis",
      "dest": "/api/genesis.js"
    },
    {
      "src": "/api/holder",
      "dest": "/api/holder.js"
    },
    {
      "src": "/api/nest",
      "dest": "/api/nest.js"
    },
    {
      "src": "/api/attest",
      "dest": "/api/attest.js"
    },
    {
      "src": "/api/eligibility",
      "dest": "/api/eligibility.js"
    },
    {
      "src": "/api/nest/authorize",
      "dest": "/api/nest-authorize.js"
    },
    {
      "src": "/api/nest/check",
      "dest": "/api/nest-check.js"
    },
    {
      "src": "/holders",
      "dest": "/mint-page/holders.html"
    },
    {
      "src": "/(.*)",
      "dest": "/mint-page/index.html"
    }
  ]
}
